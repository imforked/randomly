{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "index.ts",
    "utils.ts",
    "lib/**/*.ts",
    "routes/**/*.ts",
    "schemas/**/*.ts",
    "controllers/**/*.ts",
    "services/**/*.ts",
    "middleware/**/*.ts",
    "constants/**/*.ts"
  ]
}
